{
  "name": "@aubwang/consult",
  "version": "0.1.2",
  "description": "Host-neutral delegation CLI for ACP coding agents.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aubwang/consult.git"
  },
  "homepage": "https://github.com/aubwang/consult#readme",
  "bugs": {
    "url": "https://github.com/aubwang/consult/issues"
  },
  "keywords": [
    "acp",
    "agent",
    "coding-agent",
    "delegation"
  ],
  "files": [
    "bin/",
    "dist/",
    "scripts/build-package.mjs",
    "skills/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "consult": "bin/consult"
  },
  "scripts": {
    "build:package": "node scripts/build-package.mjs",
    "pack:check": "node scripts/package-smoke.mjs",
    "prepack": "node scripts/build-package.mjs",
    "prepare": "node scripts/build-package.mjs",
    "test": "node --test \"scripts/**/*.test.mts\"",
    "typecheck": "tsc --noEmit",
    "drill:companion-disconnect": "node scripts/live-companion-disconnect-drill.mts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  }
}
